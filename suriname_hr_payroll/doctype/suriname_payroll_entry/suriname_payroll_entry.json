      "fieldname": "column_break_4",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "posting_date",
      "fieldtype": "Date",
      "label": "Posting Date",
      "default": "Today"
    },
    {
      "fieldname": "status",
